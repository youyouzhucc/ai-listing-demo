# 复制为 .env.deploy 后填写（.env.deploy 已在 .gitignore，勿提交密钥）
#
# 部署方式二选一：
#   DEPLOY_TARGET=oss   → 同步到 OSS 静态网站托管
#   DEPLOY_TARGET=ssh   → rsync 到 ECS 上 Nginx 站点目录

DEPLOY_TARGET=oss

# ---------- OSS（DEPLOY_TARGET=oss）----------
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_PREFIX=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ---------- SSH / rsync（DEPLOY_TARGET=ssh）----------
# SSH_USER=root
# SSH_HOST=47.xxx.xxx.xxx
# SSH_PORT=22
# REMOTE_DIR=/var/www/ai-listing-demo
# SSH_IDENTITY=~/.ssh/id_rsa
# 部署后执行：ssh ... 'sudo nginx -s reload'（可选）
# NGINX_RELOAD_CMD='sudo nginx -s reload'
